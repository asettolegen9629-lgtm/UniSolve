# Скопируйте этот файл в .env и заполните своими данными
# Или используйте локальную БД (по умолчанию)

# Для локальной БД (каждый видит свои посты):
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/unislove_db?schema=public"

# Для общей БД (все видят одни посты) - используйте Supabase/Neon:
# DATABASE_URL="postgresql://postgres:ВАШ_ПАРОЛЬ@db.xxxxx.supabase.co:5432/postgres"

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/unislove_db?schema=public"
PORT=3000
